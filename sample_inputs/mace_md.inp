# Sample input file for a MD simulation with the Nose-Hoover Chain Thermostat
# in the NVT ensemble

# The method that sould be used to calculate energies and gradients
pes mace
# Apply the Grimme D3 dispersion correction
dispersion

mace {
  # Type of the MACE model
  # mp:   foundation models trained on Materials Project data
  # omol: foundation models trained on OMOL data
  mlip_type mp
  # Path to the MACE model
  mlip_file /home/hpc/b146dc/b146dc13/progs/ASE/MACE_models/mace_agnesi_medium.model
  # Cuda or cpu
  device cuda
}

# ensemble activates the MD routine
ensemble nvt
steps 100
dt 1.0
# Write out frequency (every Nth step energies and gradients are written)
steps_freq 1

# Seed for choosing the initial velocities
seed 15876
# Remove translation of the center-of-mass
stationary
# Remove rotation around the center-of-mass
zero_rotation

nvt {
  temperature 300
  thermostat nose-hoover
  # Fictious mass of the additional degree of freedom s
  smass 40
  # Number of chains in the Nose-Hoove Chain Thermostat
  chains 3
}

